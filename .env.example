# Local dev (default): SQLite, zero external accounts.
DATABASE_URL="file:./dev.db"

# Production: Neon Postgres. Set this same value as:
#   - a Vercel project env var (for the web app)
#   - a GitHub Actions repo secret named DATABASE_URL (for the scraper)
# DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# Selects the Prisma datasource provider at build time (sqlite|postgresql).
# Local dev leaves this unset (defaults to sqlite). Prod builds set postgresql.
# PRISMA_DB_PROVIDER="postgresql"

# TMDB API key (themoviedb.org → free, Settings → API → API Key v3 auth).
# Used ONLY by the scraper to fetch movie posters; the web app never calls TMDB.
# Set it locally here AND as a GitHub Actions repo secret named TMDB_API_KEY.
# Without it, scrapes still work — posters just stay empty.
# TMDB_API_KEY="your-tmdb-v3-api-key"
